# Copy to .env.local and fill in. SERVER-ONLY — never exposed to the browser.
#
# The agent's Terminal 3 identity is derived from an Ethereum private key.
# NOTE: AGENTS.md calls this "T3N_API_KEY", but the real @terminal3/t3n-sdk
# has no API-key concept — it authenticates via an ETH private key (or OIDC).
# Use any 32-byte hex key for testnet: `openssl rand -hex 32`, prefixed 0x.
T3N_AGENT_PRIVATE_KEY=0x...

# Prisma + SQLite. Also add this to a root .env file so the Prisma CLI
# (db push / seed / studio) can read it. Path is relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Demo BUYER signer (Step 3). In production the buyer signs the delegation
# credential in their own wallet; this key stands in for the demo. SERVER-ONLY.
T3N_DEMO_BUYER_PRIVATE_KEY=0x...

# Stripe Connect (Step 4) — OPTIONAL. Leave unset to run the offline escrow
# simulator (pi_sim_/tr_sim_ refs). Set a TEST key (sk_test_…) for real
# test-mode calls; a live key (sk_live_…) is rejected by design. SERVER-ONLY.
# STRIPE_SECRET_KEY=sk_test_...
# Map of exporter reference -> Connect destination account id (JSON). When
# unset, destinations are simulated as acct_sim_<hash>.
# STRIPE_DESTINATIONS={"exporter-ref:acme-textiles-001":"acct_123"}
